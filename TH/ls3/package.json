{
  "name": "ls3",
  "version": "1.0.0",
  "description": "Lesson 3 - Express + JSON Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:express": "node server.js",
    "start:json": "json-server --watch db.json --port 3001",
    "dev": "concurrently \"npm run start:express\" \"npm run start:json\""
  },
  "dependencies": {
    "axios": "^1.9.0",
    "concurrently": "^9.1.2",
    "express": "^4.18.2",
    "json-server": "^1.0.0-beta.3"
  }
}
